                    <!-- Code folding: normally auto-generated by LanguageRegistrationProcessor
                         from @LanguageRegistration, but annotation processing is disabled
                         (-proc:none) so registered manually here.
                         GsfFoldManagerFactory drives GsfFoldManager, which calls
                         KotlinStructureScanner.folds() and makes the +/- collapse controls
                         appear in the gutter (THE fix — without it GsfFoldManager never runs).
                         KotlinFoldTypeProvider supplies named/templated Kotlin FoldTypes
                         (codes imports/comments/codeblocks, matching KotlinFoldingVisitor's
                         keys); it lives in the FoldManager folder because FoldTypeProvider is
                         @MimeLocation(subfolderName="FoldManager"), and also lists those types
                         in Tools > Options > Editor > Folding like Java. -->
                    <folder name="FoldManager">
                        <file name="org-netbeans-modules-csl-editor-fold-GsfFoldManagerFactory.instance">
                            <attr name="position" intvalue="1000"/>
                        </file>
                        <file name="io-github-nbplugins-kotlin-nbm-structurescanner-KotlinFoldTypeProvider.instance">
                            <attr name="instanceOf" stringvalue="org.netbeans.spi.editor.fold.FoldTypeProvider"/>
                            <attr name="position" intvalue="1100"/>
                        </file>
                    </folder>
                    <!-- code-folding-enable is already true by inheritance from the editor
                         module's global default (Editors/Preferences/Defaults); this per-MIME
                         file sets it explicitly so folding does not depend on that default. -->
                    <folder name="Preferences">
                        <folder name="Defaults">
                            <file name="org-jetbrains-kotlin-preferences.xml" url="DefaultPreferences.xml"/>
                        </folder>
                    </folder>
                </folder>
